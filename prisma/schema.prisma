generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model PdfDocument {
  id        String   @id @default(cuid())
  title     String
  subject   String
  date      String
  jsonData  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pdf_documents")
}

model Book {
  id            String       @id @default(cuid())
  title         String
  description   String?
  fileName      String
  fileSize      Int
  filePath      String
  category      BookCategory
  classLevel    String?
  extractedText String?      @db.Text
  pageCount     Int?
  uploadedAt    DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("books")
}

enum BookCategory {
  CLASSES
  COURSES
  COACHING
  NOTES
  REFERENCE
  OTHER
}
